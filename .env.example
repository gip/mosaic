# --- @mosaic/mcp (server) ---
# Postgres connection string (docker-compose default below)
MOSAIC_DATABASE_URL=postgres://mosaic:mosaic@localhost:5432/mosaic

# Xaman (xumm) API credentials — https://apps.xaman.dev
# The secret NEVER reaches the browser; all Xaman payloads are created server-side.
XAMAN_API_KEY=
XAMAN_API_SECRET=

# HTTP port for the MCP server
MOSAIC_MCP_PORT=8788

# Bind address (host:port). Overrides MOSAIC_MCP_PORT. Default binds loopback
# only; use 0.0.0.0 to reach the server from other devices (e.g. phone on LAN).
# MOSAIC_BIND=0.0.0.0:8788

# Comma-separated browser origins allowed by CORS.
# Default: http://localhost:5173,http://127.0.0.1:5173 — and outside
# NODE_ENV=production any loopback origin is allowed automatically.
# Add your frontend's origin(s) when serving it from elsewhere:
# MOSAIC_CORS_ORIGIN=http://localhost:5173,http://192.168.1.20:5173,https://app.example.com

# Optional XRPL JSON-RPC overrides (defaults: xrplcluster.com / s.altnet.rippletest.net)
# MOSAIC_XRPL_RPC_MAINNET=
# MOSAIC_XRPL_RPC_TESTNET=

# --- frontend (Vite; VITE_* vars are PUBLIC — never put secrets here) ---
# WalletConnect / Reown Cloud project id — https://cloud.reown.com
# Required for the default mobile-wallet QR login (MetaMask mobile, Freighter
# mobile); extension-fallback logins work without it.
VITE_WALLETCONNECT_PROJECT_ID=
# MCP server URL
VITE_MCP_URL=http://localhost:8788/mcp

# Dev-only: adds a "Demo wallet" button (in-page deterministic EVM key) to the
# login modal so every flow can be driven without a wallet extension.
# Ignored by production builds. NEVER a key holding real funds.
# VITE_DEMO_WALLET=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
