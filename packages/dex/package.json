{
  "name": "@mosaic/dex",
  "version": "0.0.0",
  "description": "Chain-agnostic DEX order-book feeds (Stellar, XRPL; EVM pending) with streaming updates",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js",
